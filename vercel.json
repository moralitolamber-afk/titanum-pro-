{
  "version": 2,
  "builds": [
    {
      "src": "api_server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api_server.py"
    }
  ],
  "env": {
    "GROQ_API_KEY": "@groq_api_key",
    "BINANCE_API_KEY": "@binance_api_key",
    "BINANCE_SECRET": "@binance_secret"
  }
}
